# Authentication for live LLM runs (Tier 3c V4 + Tier 4-live V5).
# Tier 4 cache replay (run_v5_score_all.py --no-llm) needs NO keys.
#
# Usage: copy this file to .env and fill in the value(s) for whichever
# provider(s) you'll use. Both run_v4_hybrid.py and run_v5_score_all.py
# call load_dotenv() at startup, so .env is picked up automatically.

# --- API-key providers (read by their Python SDKs) ------------------------

# --llm-provider anthropic
ANTHROPIC_API_KEY=
# Optional model override (default: haiku)
# ANTHROPIC_MODEL=haiku

# --llm-provider openai
OPENAI_API_KEY=
# Optional model override
# OPENAI_MODEL=

# --llm-provider zai-coding   (Anthropic-compatible proxy at api.z.ai)
ZAI_API_KEY=
# Optional model override (default: glm-4.7)
# ZAI_MODEL=glm-4.7

# --- OAuth-based providers (no key here; log in once via the CLI) ---------

# --llm-provider codex-cli
#   1. Install: npm install -g @openai/codex
#   2. Login:   codex login
# Optional overrides (defaults: gpt-5.4-mini, low):
# CODEX_MODEL=gpt-5.4-mini
# CODEX_REASONING_EFFORT=low

# --llm-provider claude-code
#   1. Install: npm install -g @anthropic-ai/claude-code
#   2. Login:   claude (interactive once)
# Optional overrides (defaults: haiku, low):
# CLAUDE_MODEL=haiku
# CLAUDE_EFFORT=low
